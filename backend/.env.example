# Use postgresql+asyncpg (or plain postgresql:// — auto-normalized). Do not use +psycopg2 for the API.
DATABASE_URL=postgresql+asyncpg://myle:myle@localhost:5432/myle
# Optional: path to Vite ``dist/`` (``index.html`` + ``assets/``) to serve the SPA from this API (same-origin auth).
# Leave unset for API-only. Docker monorepo image sets ``FRONTEND_DIST=/app/frontend_dist``.
# FRONTEND_DIST=

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECRET_KEY=change-me-in-production-use-long-random-string
# Access JWT (minutes) + refresh JWT (days); cookies set on login / dev-login / refresh
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=14
# Max POSTs per client IP per minute on /api/v1/auth/login|dev-login|refresh (0 = off)
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=30
# Local only: cookie JWT dev login (POST /api/v1/auth/dev-login) — requires migrated DB with seeded dev users
AUTH_DEV_LOGIN_ENABLED=true
# Production split host (SPA + API on different origins): SESSION_COOKIE_SECURE=true and AUTH_COOKIE_SAMESITE=none
# SESSION_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax

# Client bootstrap: GET /api/v1/meta (JSON only — not webhooks). Environment badge in dashboard.
APP_ENV=development
# Work → Intelligence nav (FEATURE_AI_INTELLIGENCE still accepted for older .env)
FEATURE_INTELLIGENCE=true

# Production / staging compose: see repo root `docker-compose.prod.yml` and `config/.env.production.example`

# --- Optional: legacy Flask SQLite → PostgreSQL import (`scripts/import_legacy_sqlite.py`) ---
# Path to old monolith `leads.db` (can also pass `--legacy-db` on the CLI).
# LEGACY_SQLITE_PATH=/absolute/path/to/leads.db
# Plain password for imported users when legacy `password` is not bcrypt (Werkzeug, etc.).
# IMPORT_DEFAULT_PASSWORD=ChangeMeAfterImport!
