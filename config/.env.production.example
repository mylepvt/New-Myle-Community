# Copy to repo root as `.env.production` and use with:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up --build
#
# Never commit real `.env.production` (secrets).

# --- Postgres (must match DATABASE_URL credentials if you customize) ---
POSTGRES_USER=myle
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=myle

# --- Backend ---
# Async URL must match compose service name `db` and the DB name above.
DATABASE_URL=postgresql+asyncpg://myle:change-me-strong-password@db:5432/myle
SECRET_KEY=change-me-min-32-chars-random
APP_ENV=production
FEATURE_INTELLIGENCE=false
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=14
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=30
# Comma-separated browser origins allowed to call the API (your real frontend URL(s))
BACKEND_CORS_ORIGINS=https://app.example.com
# Password login uses POST /api/v1/auth/login — keep dev-login off in prod
AUTH_DEV_LOGIN_ENABLED=false
SESSION_COOKIE_SECURE=true
# Split static site + API (e.g. Render): browsers need SameSite=None + Secure for cross-origin cookie auth
AUTH_COOKIE_SAMESITE=none

# Publish ports (host)
BACKEND_PUBLISH_PORT=8000
FRONTEND_PUBLISH_PORT=5173

# --- Frontend container (Vite dev image reads this at runtime) ---
VITE_API_URL=https://api.example.com
